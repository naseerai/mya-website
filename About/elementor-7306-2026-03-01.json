sLength = dmGsapCards.length;\n\n  \/\/ \u2705 Set stable initial state (prevents jump)\n  gsap.set(dmGsapCards, { clearProps: \"all\" });\n\n  dmGsapCards.forEach((dmElement, index) => {\n\n    const dmCardsOffset = -15 * (index + 1);\n    const scaleValue = (100 - dmCardsLength) \/ 100 + ((index + 1) * 0.01);\n    const opacityValue = (1 - dmGsapCards.length \/ 10) + ((index + 1) * 0.1);\n\n    ScrollTrigger.create({\n      trigger: dmElement,\n      endTrigger: '.dm-gsap-cards-end',\n      start: `0%+=${dmCardsOffset}px 15%`,\n      end: '0% 15%',\n      pin: true,\n      scrub: true,\n      anticipatePin: 1,\n      invalidateOnRefresh: true\n    });\n\n    if (index < dmGsapCards.length - 1) {\n      const nextElement = dmGsapCards[index + 1];\n\n      ScrollTrigger.create({\n        trigger: nextElement,\n        start: '50% 50%',\n        end: '50% 50%',\n        onEnter: () => {\n          gsap.to(dmElement, {\n            opacity: opacityValue,\n            scale: scaleValue,\n            duration: 0.4,\n            transformOrigin: 'top center'\n          });\n        },\n        onLeaveBack: () => {\n          gsap.to(dmElement, {\n            opacity: 1,\n            scale: 1,\n            duration: 0.4\n          });\n        }\n      });\n    }\n\n  });\n\n  \/\/ \u2705 FORCE recalculation AFTER everything loads\n  ScrollTrigger.refresh();\n\n});\n<\/script>","_title":"Code 1"},"elements":[],"isInner":false,"widgetType":"html","elType":"widget"}],"isInner":false,"elType":"container"}],"page_settings":{"hide_title":"yes"},"version":"0.4","title":"About-3","type":"container"}