\n      clearProps: \"transform\"\n    });\n\n  });\n\n  \/\/ Wait till layout is stable\n  setTimeout(() => {\n    ScrollTrigger.refresh();\n  }, 300);\n\n});\n<\/script>"},"elements":[],"isInner":false,"widgetType":"html","elType":"widget"}],"isInner":false,"elType":"container"}],"page_settings":{"hide_title":"yes"},"version":"0.4","title":"Home-6","type":"container"}