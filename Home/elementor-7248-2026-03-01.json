{"content":[{"id":"cd0b0a7","settings":{"flex_direction":"column","content_width":"full","min_height":{"unit":"px","size":500,"sizes":[]},"flex_justify_content":"center","flex_align_items":"center","ma_el_slider_delay":"5000","padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"min_height_mobile":{"unit":"px","size":320,"sizes":[]},"_title":"Home-9"},"elements":[{"id":"60fe1931","settings":{"html":"<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Industry Carousel<\/title>\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Inter:wght@400;500;600&display=swap\" rel=\"stylesheet\">\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background: #fff;\n  }\n\n  \/* \u2500\u2500 Viewport \u2500\u2500 *\/\n  .carousel-viewport {\n  overflow: hidden;\n  cursor: grab;\n  user-select: none;\n  width: 100%;\n  touch-action: pan-y; \/* \u2b50 REQUIRED *\/\n  padding-left: clamp(20px, 4vw, 64px);\n  padding-right: clamp(20px, 4vw, 64px);\n}\n  .carousel-viewport:active { cursor: grabbing; }\n\n  .carousel-track {\n  padding-right: 2px;\n  display: flex;\n  gap: 16px;\n  flex-wrap: nowrap;\n  will-change: transform;\n}\n.carousel-viewport {\n  cursor: grab;\n}\n\n.carousel-viewport:active {\n  cursor: grabbing;\n}\n\n  \/* \u2500\u2500 Card \u2500\u2500\n     Size is set entirely by JS based on breakpoint.\n     background-size:cover guarantees full image fill always.\n  \u2500\u2500 *\/\n  .card {\n    flex-shrink: 0;\n    flex-grow: 0;\n    border-radius: 16px;\n    overflow: hidden;\n    position: relative;\n    background-color: #222;\n    background-size: cover;\n    background-position: center center;\n    background-repeat: no-repeat;\n    \/* transition size smoothly on resize *\/\n    transition: width 0.3s ease, height 0.3s ease;\n  }\n\n  .card-video {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    object-position: center;\n    opacity: 0;\n    transition: opacity 0.4s ease;\n    z-index: 1;\n  }\n  .card:hover .card-video { opacity: 1; }\n\n  .card-gradient {\n    position: absolute;\n    bottom: 0; left: 0; right: 0;\n    height: 100px;\n    background: linear-gradient(to top, rgba(0,0,0,0.55), transparent);\n    z-index: 2;\n    pointer-events: none;\n  }\n\n  .card-label {\n    position: absolute;\n    top: 18px; left: 20px;\n    color: #fff;\n    font-size: 18px; font-weight: 500;\n    line-height: 1.3;\n    text-shadow: 0 1px 6px rgba(0,0,0,0.5);\n    z-index: 3;\n    pointer-events: none;\n  }\n\n  \/* \u2500\u2500 Progress bar \u2500\u2500 *\/\n  .progress-wrap {\n    margin-top: 24px;\n    display: flex;\n    justify-content: center;\n  }\n\n  .progress-track {\n    position: relative;\n    width: min(580px, 70vw);\n    padding: 12px 0;\n    margin: -12px 0;\n    cursor: pointer;\n  }\n\n  .progress-line {\n    width: 100%;\n    height: 3px;\n    background: #e0e0e0;\n    border-radius: 2px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .progress-pill {\n    position: absolute;\n    top: 0; left: 0;\n    width: 30%;\n    height: 100%;\n    border-radius: 2px;\n    background: linear-gradient(90deg, #f87171, #818cf8);\n    transform: translateX(0px);\n    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);\n  }\n<\/style>\n<\/head>\n<body>\n\n<div class=\"carousel-viewport\" id=\"carouselViewport\">\n  <div class=\"carousel-track\" id=\"carouselTrack\">\n\n    <div class=\"card\" style=\"background-image:url('https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/soldering-rework.jpg')\">\n      <video class=\"card-video\" muted loop playsinline preload=\"none\" src=\"https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/service-1.mp4\"><\/video>\n      <div class=\"card-gradient\"><\/div>\n      <span class=\"card-label\">Soldering & Rework<\/span>\n    <\/div>\n\n    <div class=\"card\" style=\"background-image:url('https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/PCB-Design.png')\">\n      <video class=\"card-video\" muted loop playsinline preload=\"none\" src=\"https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/pcb-design-.mp4\"><\/video>\n      <div class=\"card-gradient\"><\/div>\n      <span class=\"card-label\">PCB Design<\/span>\n    <\/div>\n\n    <div class=\"card\" style=\"background-image:url('https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/Embedded-Developement.png')\">\n      <video class=\"card-video\" muted loop playsinline preload=\"none\" src=\"https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/Embedded-Development.mp4\"><\/video>\n      <div class=\"card-gradient\"><\/div>\n      <span class=\"card-label\">Embedded Development<\/span>\n    <\/div>\n\n    <div class=\"card\" style=\"background-image:url('https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/PCB-fabrication-.png')\">\n      <video class=\"card-video\" muted loop playsinline preload=\"none\" src=\"https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/pcb-fabrication.mp4\"><\/video>\n      <div class=\"card-gradient\"><\/div>\n      <span class=\"card-label\">PCB Fabrication\n<\/span>\n    <\/div>\n\n    <div class=\"card\" style=\"background-image:url('https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/representation-user-experience-interface-design-scaled.jpg')\">\n      <video class=\"card-video\" muted loop playsinline preload=\"none\" src=\"https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/web-dev.mp4\"><\/video>\n      <div class=\"card-gradient\"><\/div>\n      <span class=\"card-label\">Full Stack Development\n<\/span>\n    <\/div>\n\n    <div class=\"card\" style=\"background-image:url('https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/3d-printing.png')\">\n      <video class=\"card-video\" muted loop playsinline preload=\"none\" src=\"https:\/\/myaccess.cloud\/wp-content\/uploads\/2026\/02\/3d-printing.mp4\"><\/video>\n      <div class=\"card-gradient\"><\/div>\n      <span class=\"card-label\">3D Printing\n<\/span>\n    <\/div>\n\n  <\/div>\n<\/div>\n\n<div class=\"progress-wrap\">\n  <div class=\"progress-track\" id=\"progressTrack\">\n    <div class=\"progress-line\" id=\"progressLine\">\n      <div class=\"progress-pill\" id=\"progressPill\"><\/div>\n    <\/div>\n  <\/div>\n<\/div>\n\n<script>\nlet currentX = 0;      \/\/ real pixel position\nlet targetX  = 0;      \/\/ where we want to go\nlet maxScroll = 0;\nlet isDown = false;\nlet isTouch = false;   \/\/ \u2705 ADD THIS\n(function () {\n  const viewport  = document.getElementById('carouselViewport');\n  const track     = document.getElementById('carouselTrack');\n  const pill      = document.getElementById('progressPill');\n  const progTrack = document.getElementById('progressTrack');\n  const progLine  = document.getElementById('progressLine');\n  const cards     = Array.from(track.querySelectorAll('.card'));\n\n  const TOTAL      = cards.length;   \/\/ 6\n  const GAP        = 16;\n  const PEEK = window.innerWidth < 600 ? 40 : 64;  \/\/ px of next card always peeking on right\n  const MAX_CARD   = 418; \/\/ max card size on large screens\n\n  let current   = 0;\n  let isCarDrag = false;\n  let isBarDrag = false;\n  let dragDelta = 0;\n  let startX    = 0;\n\n  \/* \u2500\u2500 Responsive breakpoints \u2500\u2500\n     mobile  (<600px) : 1 card visible\n     tablet  (<1024px): 2 cards visible\n     desktop (>=1024px): 3 cards visible, max 418px\n  \u2500\u2500 *\/\n  function getConfig() {\n    const vw = getInnerViewportWidth();\n\nif (vw < 600) {\n  \/\/ one full card + right peek\n  const cw = Math.min(\n    MAX_CARD,\n    Math.floor(vw - PEEK)\n  );\n  const ch = cw;\n  return { cols: 1, cw, ch };\n}else if (vw < 1024) {\n      \/\/ 2 cards + peek\n      const cw = Math.min(MAX_CARD, Math.floor((vw - GAP - PEEK) \/ 2));\n      const ch = cw;\n      return { cols: 2, cw, ch };\n    } else {\n      \/\/ 3 cards + peek \u2014 card max 418px\n      const cw = Math.min(MAX_CARD, Math.floor((vw - 2 * GAP - PEEK) \/ 3));\n      const ch = cw;\n      return { cols: 3, cw, ch };\n    }\n  }\nfunction getInnerViewportWidth() {\n  const style = getComputedStyle(viewport);\n  const pl = parseFloat(style.paddingLeft) || 0;\n  const pr = parseFloat(style.paddingRight) || 0;\n  return viewport.clientWidth - pl - pr;\n}\n  function maxIndex() {\n  const cw = sizeCards();\n  const innerWidth = getInnerViewportWidth();\n\n  maxScroll = Math.max(\n    0,\n    track.scrollWidth - innerWidth\n  );\n\n  const totalWidth = TOTAL * cw + (TOTAL - 1) * GAP;\n  return Math.max(0, Math.ceil((totalWidth - innerWidth) \/ (cw + GAP)));\n}\n\n  function sizeCards() {\n    const { cw, ch } = getConfig();\n    cards.forEach(c => {\n      c.style.width     = cw + 'px';\n      c.style.flexBasis = cw + 'px';\n      c.style.height    = ch + 'px';\n    });\n    return cw;\n  }\n\n  \/* \u2500\u2500 Progress bar \u2500\u2500 *\/\n  function setBarFraction(frac, animate) {\n    frac = Math.max(0, Math.min(1, frac));\n    const lw     = progLine.offsetWidth;\n    const pw     = lw * 0.30;\n    const offset = (lw - pw) * frac;\n    pill.style.transition = animate\n      ? 'transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';\n    pill.style.transform  = `translateX(${offset}px)`;\n  }\n\n  \/* \u2500\u2500 Render \u2500\u2500 *\/\n  function render(animate) {\n    const cw  = sizeCards();\n    \n\n    track.style.transition = animate\n      ? 'transform 0.55s cubic-bezier(0.25,0.46,0.45,0.94)' : 'none';\n    \nconst innerWidth = getInnerViewportWidth();\n\nmaxScroll = Math.max(\n  0,\n  track.scrollWidth - innerWidth\n);\n\n\/\/ clamp smooth target instead of snapping\ntargetX = Math.max(0, Math.min(targetX, maxScroll));\n    const frac = maxScroll === 0 ? 0 : currentX \/ maxScroll;\nsetBarFraction(frac, false);\n  }\n\n  function goTo(idx, animate = true) {\n    current = Math.max(0, Math.min(idx, maxIndex()));\n    render(animate);\n  }\n\n  \/* \u2500\u2500 Progress bar interaction \u2500\u2500 *\/\n  function barFracFromX(clientX) {\n    const rect = progLine.getBoundingClientRect();\n    const pw   = rect.width * 0.30;\n    return (clientX - rect.left - pw \/ 2) \/ (rect.width - pw);\n  }\n  function barIdxFromX(clientX) {\n    return Math.round(Math.max(0, Math.min(1, barFracFromX(clientX))) * maxIndex());\n  }\n\n  progTrack.addEventListener('click', e => {\n    if (isBarDrag) return;\n    targetX = maxScroll *\n  Math.max(0, Math.min(1, barFracFromX(e.clientX)));\n  });\n\n  progTrack.addEventListener('mousedown', e => {\n    isBarDrag = false;\n    const onMove = ev => {\n      isBarDrag = true;\n      setBarFraction(barFracFromX(ev.clientX), false);\n    };\n    const onUp = ev => {\n      window.removeEventListener('mousemove', onMove);\n      window.removeEventListener('mouseup', onUp);\n      targetX = maxScroll *\n  Math.max(0, Math.min(1, barFracFromX(ev.clientX)));\n      setTimeout(() => { isBarDrag = false; }, 50);\n    };\n    window.addEventListener('mousemove', onMove);\n    window.addEventListener('mouseup', onUp);\n    e.preventDefault(); e.stopPropagation();\n  });\n\n  progTrack.addEventListener('touchstart', e => {\n    const onMove = ev => setBarFraction(barFracFromX(ev.touches[0].clientX), false);\n    const onEnd  = ev => {\n      progTrack.removeEventListener('touchmove', onMove);\n      progTrack.removeEventListener('touchend',  onEnd);\n      goTo(barIdxFromX(ev.changedTouches[0].clientX));\n    };\n    progTrack.addEventListener('touchmove', onMove, { passive: true });\n    progTrack.addEventListener('touchend',  onEnd);\n  }, { passive: true });\n\n  \/* \u2500\u2500 Hover: play video \u2500\u2500 *\/\n  cards.forEach(card => {\n    const vid = card.querySelector('.card-video');\n    if (!vid) return;\n    card.addEventListener('mouseenter', () => vid.play().catch(() => {}));\n    card.addEventListener('mouseleave', () => { vid.pause(); vid.currentTime = 0; });\n  });\n\/* \u2500\u2500 Carousel mouse drag \u2500\u2500 *\/\nviewport.addEventListener('mousedown', e => {\n  if (progTrack.contains(e.target)) return;\n\n  isDown = true;\n  startX = e.pageX;\n  viewport.style.cursor = 'grabbing';\n  e.preventDefault();\n});\n\nwindow.addEventListener('mousemove', e => {\n  if (!isDown) return;\n\n  const dx = e.pageX - startX;\n  startX = e.pageX;\n\n  targetX -= dx;\n\n  \/\/ clamp while dragging\n  targetX = Math.max(0, Math.min(targetX, maxScroll));\n});\n\nwindow.addEventListener('mouseup', () => {\n  isDown = false;\n  viewport.style.cursor = 'grab';\n});\n\/* \u2500\u2500 Carousel touch drag \u2500\u2500 *\/\nviewport.addEventListener('touchstart', e => {\n  if (progTrack.contains(e.target)) return;\n\n  isTouch = true;\n  startX = e.touches[0].pageX;\n}, { passive: true });\n\nviewport.addEventListener('touchmove', e => {\n  if (!isTouch) return;\n\n  const dx = e.touches[0].pageX - startX;\n  startX = e.touches[0].pageX;\n\n  targetX -= dx;\n\n  \/\/ clamp while dragging\n  targetX = Math.max(0, Math.min(targetX, maxScroll));\n}, { passive: true });\n\nviewport.addEventListener('touchend', () => {\n  isTouch = false;\n});\n\nwindow.addEventListener('mouseup', () => {\n  isDown = false;\n  viewport.style.cursor = 'grab';\n});\n\n\n\n  \/* \u2500\u2500 Keyboard \u2500\u2500 *\/\n  document.addEventListener('keydown', e => {\n    if (e.key === 'ArrowRight') goTo(current + 1);\n    if (e.key === 'ArrowLeft')  goTo(current - 1);\n  });\n\n  \/* \u2500\u2500 Resize \u2500\u2500 *\/\n  let resizeTimer;\n  window.addEventListener('resize', () => {\n    clearTimeout(resizeTimer);\n    resizeTimer = setTimeout(() => render(false), 100);\n  });\nfunction animate() {\n  \/\/ smooth interpolation\n  currentX += (targetX - currentX) * 0.08;\n\n  track.style.transform = `translateX(${-currentX}px)`;\n\n  \/\/ sync progress bar\n  const frac = maxScroll === 0 ? 0 : currentX \/ maxScroll;\n  setBarFraction(frac, false);\n\n  requestAnimationFrame(animate);\n}\n  \/* \u2500\u2500 Init \u2500\u2500 *\/\n  render(false);\nanimate();\n})();\n<\/script>\n\n<\/body>\n<\/html>"},"elements":[],"isInner":false,"widgetType":"html","elType":"widget"}],"isInner":false,"elType":"container"}],"page_settings":{"hide_title":"yes"},"version":"0.4","title":"Home-9","type":"container"}