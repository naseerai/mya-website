);\n\n    const split = new SplitType(h2, { types: \"words\" });\n    h2.splitType = split;\n\n    gsap.from(split.words, {\n      scrollTrigger: {\n        trigger: heading,\n        start: \"top 60%\",\n        toggleActions: \"play none none none\"\n      },\n      y: 40,\n      opacity: 0,\n      duration: 0.6,\n      ease: \"power3.out\",\n      stagger: 0.06,\n      force3D: true,\n      clearProps: \"transform\"\n    });\n\n  });\n\n  \/\/ Wait till layout is stable\n  setTimeout(() => {\n    ScrollTrigger.refresh();\n  }, 300);\n\n});\n<\/script>"},"elements":[],"isInner":false,"widgetType":"html","elType":"widget"}],"isInner":true,"elType":"container"},{"id":"27a80f9e","settings":{"ma_el_slider_delay":"5000","parallax_blocks":[]},"elements":[{"id":"7d14d4d0","settings":{"editor":"<p>[fluentform id=\"3\"]<\/p>","typography_typography":"custom","typography_font_family":"Poppins","typography_font_weight":"400","_padding":{"unit":"px","top":"30","right":"30","bottom":"30","left":"30","isLinked":true}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"container"}],"isInner":false,"elType":"container"}],"page_settings":{"hide_title":"yes"},"version":"0.4","title":"Con-8","type":"container"}